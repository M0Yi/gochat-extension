{
  "name": "@m0yi/gochat",
  "version": "2026.4.8-plugin.18",
  "description": "OpenClaw GoChat channel plugin - WebSocket relay to GoChat platform (default) or local HTTP server",
  "type": "module",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.28"
    },
    "channel": {
      "id": "gochat",
      "label": "GoChat",
      "selectionLabel": "GoChat (custom)",
      "docsPath": "/channels/gochat",
      "docsLabel": "gochat",
      "blurb": "Custom chat backend via HTTP webhook. Supports relay mode (Go backend) and direct mode (built-in API).",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@m0yi/gochat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.24"
    },
    "hooks": {}
  }
}
